# Copy this file to .env.local and fill in your values

# LiveKit Server URL
# For local development: ws://localhost:7880
# For production: wss://your-livekit-server.com
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# Backend API URL
# API Configuration
# Set this to your backend API URL
# For local development: http://localhost:8000
# For ngrok: https://your-ngrok-url.ngrok.io
# For production: https://api.yourdomain.com
# Default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# LiveKit Configuration (optional)
# Set this if your LiveKit server is on a different URL
# Default: ws://localhost:7880
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

