name: AI Agent Review

on:
  workflow_dispatch:
  pull_request:
    types: [opened, synchronize, reopened]
    branches:
      - main
    paths:
      - 'Backend/**'
      - '*'
      - 'Review-agent/**'
      - '.github/workflows/ai-agent-review.yaml'

jobs:
  review:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Print PR info
        run: |
          echo "Repository: ${{ github.repository }}"
          echo "PR number: ${{ github.event.pull_request.number }}"
          echo "PR title: ${{ github.event.pull_request.title }}"
          echo "Base branch: ${{ github.event.pull_request.base.ref }}"
          echo "Head branch: ${{ github.event.pull_request.head.ref }}"
          echo "GITHUB_REF: $GITHUB_REF"
          echo "GITHUB_SHA: $GITHUB_SHA"

      - name: Fetch base branch
        run: git fetch origin main

      - name: Generate diff files
        run: |
          git diff --stat origin/main HEAD -- . ':(exclude)Review-agent/full_diff.txt' ':(exclude)Review-agent/final_summary.md' ':(exclude)Review-agent/graph.drawio' ':(exclude)**/__pycache__/**' > diff_stat.txt
          git diff origin/main HEAD -- . ':(exclude)Review-agent/full_diff.txt' ':(exclude)Review-agent/final_summary.md' ':(exclude)Review-agent/graph.drawio' ':(exclude)**/__pycache__/**' > full_diff.txt

      - name: Debug diff info
        run: |
          echo "Stat size: $(wc -c < diff_stat.txt) bytes"
          echo "Diff size: $(wc -c < full_diff.txt) bytes"
          echo "Changed files:"
          git diff --name-only origin/main HEAD -- . ':(exclude)Review-agent/full_diff.txt' ':(exclude)Review-agent/final_summary.md' ':(exclude)Review-agent/graph.drawio' ':(exclude)**/__pycache__/**' || true
          echo "Recent commits:"
          git log --oneline --decorate -n 10

      - name: Upload diff artifacts
        uses: actions/upload-artifact@v4
        with:
          name: pr-review-inputs
          path: |
            diff_stat.txt
            full_diff.txt
          if-no-files-found: error
          overwrite: true

  add-or-overwrite-pr-comment:
    needs: review
    runs-on: ubuntu-latest
    permissions:
      contents: read
      pull-requests: write
      issues: write

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Download diff artifacts
        uses: actions/download-artifact@v5
        with:
          name: pr-review-inputs

      - name: Verify downloaded files
        run: |
          ls -lah
          echo "Stat size: $(wc -c < diff_stat.txt) bytes"
          echo "Diff size: $(wc -c < full_diff.txt) bytes"

      - name: Install Python dependencies
        run: pip install -r Review-agent/requirement.txt

      - name: Fetch all PR comments
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          # 1. Get Conversation/Issue comments (Screenshot 2)
          gh api repos/${{ github.repository }}/issues/${{ github.event.pull_request.number }}/comments \
            --paginate --jq '.[] | select(.user.login != "github-actions[bot]") | {body, type: "issue"}' > issue_comments.json

          # 2. Get Review comments AND Replies (Screenshot 1)
          gh api repos/${{ github.repository }}/pulls/${{ github.event.pull_request.number }}/comments \
            --paginate --jq '.[] | select(.user.login != "github-actions[bot]") | {body, path, line, original_line, side, type: "review"}' > review_comments.json

          # 3. Combine into a valid JSON array
          jq -s 'add' <(jq -s '.' issue_comments.json) <(jq -s '.' review_comments.json) > all_comments.json
      - name: Run AI review agent
        id: ai-review
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
          GROQ_API_KEY: ${{ secrets.GROQ_API_KEY }}
        run: |
          python3 Review-agent/ai_review_agent.py \
            --diff-stats-file diff_stat.txt \
            --code-diff-file full_diff.txt \
            --comments-file all_comments.json
        working-directory: ${{ github.workspace }}

      - name: Prepend hidden marker to summary
        run: |
          echo "<!-- ai-review-bot -->" | cat - final_summary.md > temp.md && mv temp.md final_summary.md

      - name: Find previous bot comment
        id: find-comment
        uses: peter-evans/find-comment@v3
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          issue-number: ${{ github.event.pull_request.number }}
          comment-author: github-actions[bot]
          body-includes: "<!-- ai-review-bot -->"

      - name: Add or overwrite PR comment
        uses: peter-evans/create-or-update-comment@v3
        with:
          token: ${{ secrets.GITHUB_TOKEN }}
          comment-id: ${{ steps.find-comment.outputs.comment-id }}
          issue-number: ${{ github.event.pull_request.number }}
          edit-mode: replace
          body-path: final_summary.md

      - name: Print all comments
        run: cat all_comments.json